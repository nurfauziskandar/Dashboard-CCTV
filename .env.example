# Salin file ini ke .env lalu isi nilainya

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=ganti-ini-dengan-secret-key-yang-kuat

# Harus sama di dashboard dan storage
STORAGE_API_TOKEN=ganti-ini-dengan-token-min-32-karakter

# Kredensial login Dashboard (port 5000)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Kredensial login Storage UI (port 8080) — set di service storage
# ADMIN_PASSWORD=storage123
