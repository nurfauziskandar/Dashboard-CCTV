# Salin file ini ke .env lalu isi nilainya sebelum docker compose up
# JANGAN commit file .env ke git

# Generate secret key:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Harus sama di dashboard dan storage — generate seperti di atas
STORAGE_API_TOKEN=

# Kredensial login Dashboard (port 5000)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Kredensial login Storage UI (port 8080)
STORAGE_ADMIN_USERNAME=
STORAGE_ADMIN_PASSWORD=
