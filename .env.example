# =============================================================================
# Dashboard CCTV — Environment Configuration (Host A)
# =============================================================================
# Copy ke .env dan ganti semua nilai placeholder.
#   cp .env.example .env
#
# Generate token / secret baru:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Generate password hash (lebih aman dari plaintext):
#   python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
# =============================================================================

# --- Mode ---
# development = demo mode (12 fake cameras, 3 fake servers)
# production  = real ONVIF + real hardware monitoring
FLASK_ENV=production

# --- Flask Session ---
# Random string. WAJIB diganti di production. Min 32 chars.
SECRET_KEY=ssJ9WwoRf0v4-sJLBErnfTwyfZTMfty-DxxTG6cIUTLlPuhp9mvMp700qUyRJ74Q

# --- Admin Login (Web UI) ---
ADMIN_USERNAME=admin
# Default plaintext (untuk dev). Override pakai ADMIN_PASSWORD_HASH di production.
ADMIN_PASSWORD=admin123
# Pre-hashed password (recommended). Set ini → ADMIN_PASSWORD diabaikan.
# ADMIN_PASSWORD_HASH=scrypt:32768:8:1$...

# --- Storage Backend (Server-Storage REST API) ---
# Kosongkan untuk disable storage integration (mode standalone).
STORAGE_URL=http://192.168.1.10:8080
# WAJIB sama dengan STORAGE_API_TOKEN di server-storage/.env
STORAGE_API_TOKEN=NzC-T8ccLIDRjlXu_jLQw4K9HwkbRm4ZR_9v-biy0iZn0BiPXxI4u7vpNH3ywJux
STORAGE_TIMEOUT=5

