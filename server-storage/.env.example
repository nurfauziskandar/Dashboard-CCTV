# =============================================================================
# Server-Storage — Environment Configuration (Host B)
# =============================================================================
# Copy ke .env dan ganti semua nilai placeholder.
#   cp .env.example .env
#
# Generate token / secret baru:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# =============================================================================

# --- Server Type ---
# vxstorage = Pelco VX Storage (default, iDRAC Redfish emulator)
# endura    = Pelco Endura NSM5200 (SNMP agent)
SERVER_TYPE=vxstorage

# --- Flask Session ---
SECRET_KEY=ZlBJ2kD22Pj60CiYXDGFWTcmpATbmk4VBgIMF3Xt34lExgAP9gWo0ItRZMvrPzDk

# --- Admin Login (Web UI) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=storage123
# ADMIN_PASSWORD_HASH=scrypt:32768:8:1$...

# --- Storage API Token (Dashboard ↔ Storage) ---
# WAJIB sama dengan STORAGE_API_TOKEN di Dashboard .env
STORAGE_API_TOKEN=NzC-T8ccLIDRjlXu_jLQw4K9HwkbRm4ZR_9v-biy0iZn0BiPXxI4u7vpNH3ywJux

# --- Signed URL Secret (HMAC-SHA256 untuk MP4 serve) ---
# Random string min 32 chars. Browser pakai signed URL, no token needed.
URL_SIGNING_SECRET=o5xFLQOE-DESDlq-9kPHLAjazEz5xdzz5JKICHEKRY7_8IhOq_x_lElZ_SMQ9s2m
SIGNED_URL_TTL_SECONDS=300

# --- Ports ---
WEB_PORT=8080
REDFISH_PORT=8443
SNMP_PORT=10161

# --- Redfish (iDRAC emulator) ---
REDFISH_USERNAME=root
REDFISH_PASSWORD=calvin

# --- SNMP (Endura emulator) ---
SNMP_COMMUNITY=public

# --- Recording ---
# RECORDINGS_DIR=  # default: ./recordings
SEGMENT_DURATION=300
VIDEO_CODEC=mp4v
VIDEO_FPS=15

# --- Retention Policy ---
RETENTION_DAYS=7
MAX_STORAGE_GB=50
CLEANUP_INTERVAL=300
